# ==============================
# ASE-JSCC .gitignore
# ==============================

# -------- OS / Editor --------
.DS_Store
Thumbs.db
.vscode/
.idea/

# -------- Python --------
__pycache__/
*.py[cod]
*.pyo
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# -------- Virtual Env --------
.env
.env.*
.venv/
venv/
env/
conda-meta/
*.egg-info/

# -------- Build / Package --------
build/
dist/
*.egg

# -------- ML Artifacts --------
# root-level outputs
checkpoint/
logs/
runs/

# nested experiment outputs
**/checkpoint/
**/logs/
**/runs/

# model files and tensorboard events
*.pth
*.pt
*.ckpt
*.onnx
events.out.tfevents.*

# -------- Datasets / Large Files --------
data/
*.zip
*.rar
*.7z
*.tar
*.tar.gz

# -------- Temporary --------
*.tmp
*.temp
*.bak
*.swp
